# ⚙️ Runtime Environment (development | staging | production)
# Controls database isolation and build mode.
NUXT_ENV=development

# 🗄️ Database path (defaults to env-specific name if not set)
# Development → ./server/db/autoforge-dev.db
# Staging    → ./server/db/autoforge-staging.db
# Production → ./server/db/autoforge-prod.db
# DATABASE_URL=./server/db/autoforge.db

# 🔑 JWT Secret (use a strong unique value in production!)
JWT_SECRET=autoforge-hub-dev-secret-key

# Alibaba Cloud OSS Configuration
# Set these to enable OSS file storage (scripts, avatars, etc.)
NUXT_OSS_ACCESS_KEY_ID=your-access-key-id
NUXT_OSS_ACCESS_KEY_SECRET=your-access-key-secret
NUXT_OSS_BUCKET=your-bucket-name
NUXT_OSS_REGION=oss-cn-hangzhou
NUXT_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Resend (password reset emails)
RESEND_API_KEY=re_xxxx
RESEND_FROM=Autoforge Hub <noreply@yourdomain.com>
